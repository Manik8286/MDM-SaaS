# App
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-256-bit-random-string
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://mdm:mdm@localhost:5432/mdmdb

# AWS
AWS_REGION=ap-south-1
SQS_COMMAND_QUEUE_URL=http://localhost:4566/000000000000/mdm-commands

# APNs (Apple Push Notification Service)
# In production: store in Secrets Manager, reference by ARN
# In dev: use file paths
APNS_CERT_SECRET_ARN=
APNS_KEY_SECRET_ARN=
APNS_CERT_PATH=./certs/dev/apns.pem
APNS_KEY_PATH=./certs/dev/apns.key
APNS_USE_SANDBOX=true

# MDM profile signing
MDM_SIGNING_CERT_PATH=./certs/dev/mdm_signing.pem
MDM_SIGNING_KEY_PATH=./certs/dev/mdm_signing.key

# CA cert for mTLS device authentication
MDM_CA_CERT_PATH=./certs/dev/ca.pem
